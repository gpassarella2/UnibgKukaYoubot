import rclpy
from rclpy.node import Node
from sensor_msgs.msg import LaserScan
from geometry_msgs.msg import Twist

class YoubotSimpleAvoidance(Node):
    def __init__(self):
        super().__init__('youbot_simple_avoidance')

        self.subscription = self.create_subscription(
            LaserScan, 'scan_webots', self.scan_callback, 10)
        self.publisher_ = self.create_publisher(Twist, 'rover_twist', 10)
        
        self.get_logger().info('Logica Intelligente Avviata (Confronto Destra/Sinistra)')

    def scan_callback(self, msg):
        ranges = msg.ranges
        if not ranges:
            return
        
        num_raggi = len(ranges)
        
        # --- 1. DEFINIZIONE SETTORI (CORRETTO: Index 900 è FRONTE) ---
        # Dai log: Index 0 (Back) è ostruito a 0.27m. Index 900 (B) aumenta andando indietro -> Guarda Avanti.
        
        centro = num_raggi // 2 # 900
        
        # Fronte: Solo 5 raggi centrali (come richiesto)
        # centro è 900. Quindi da 898 a 903 (5 raggi)
        front_ranges = ranges[centro-2 : centro+3]
        
        # Sinistra: Tutto ciò che è a sinistra del centro (Index 903 a 1350)
        left_ranges = ranges[centro+3 : centro+450]
        
        # Destra: Tutto ciò che è a destra del centro (Index 450 a 898)
        right_ranges = ranges[centro-450 : centro-2]
        
        # Retro (Debug): Index 0-100
        rear_ranges = ranges[0:100] + ranges[-100:]
        
        # --- 2. FUNZIONE UTILITY ---
        def get_min_dist(sector_ranges):
            # Abbassato filtro a 0.02 per vedere ostacoli vicinissimi
            validi = [r for r in sector_ranges if r > 0.02 and r != float('inf')]
            return min(validi) if validi else 10.0

        min_front = get_min_dist(front_ranges)
        min_left = get_min_dist(left_ranges)
        min_right = get_min_dist(right_ranges)
        min_rear = get_min_dist(rear_ranges)

        # --- 3. LOGICA DI CONTROLLO ---
        cmd = Twist()
        
        # Parametri aumentati per reattività
        DISTANZA_SICUREZZA = 1.5
        DISTANZA_CRITICA = 0.8
        DISTANZA_EMERGENZA = 0.5
        
        self.get_logger().info(f'F: {min_front:.2f} L: {min_left:.2f} R: {min_right:.2f} B: {min_rear:.2f}')

        # CHECK COLLISIONE FRONTALE CIECA (Side Pinch)
        # Se F non vede nulla (10.0) ma L e R sono vicinissimi (< 0.2), siamo contro un muro!
        side_pinch = (min_left < 0.2 and min_right < 0.2)

        if min_front < DISTANZA_EMERGENZA or side_pinch:
            # TROPPO VICINO o SCHIACCIATO: Indietro e Ruota
            self.get_logger().info('EMERGENZA! Indietro')
            cmd.linear.x = -0.3
            cmd.angular.z = 1.0 
            
        elif min_front < DISTANZA_CRITICA:
            # SITUAZIONE CRITICA: Stop e Ruota
            cmd.linear.x = 0.0
            
            # Isteresi / Simmetria
            delta = min_left - min_right
            if abs(delta) < 0.2:
                cmd.angular.z = 1.5 # Forza SX Veloce
                self.get_logger().info('CRITICO (Simmetrico) -> Forza SX')
            elif min_left > min_right:
                cmd.angular.z = 1.5
                self.get_logger().info('CRITICO! Giro SX')
            else:
                cmd.angular.z = -1.5
                self.get_logger().info('CRITICO! Giro DX')
                
        elif min_front < DISTANZA_SICUREZZA:
            # RALLENTA E CURVA
            cmd.linear.x = 0.4 * (min_front / DISTANZA_SICUREZZA)
            
            if min_left > min_right:
                cmd.angular.z = 1.0
                self.get_logger().info('Evito a SX')
            else:
                cmd.angular.z = -1.0
                self.get_logger().info('Evito a DX')
                
        else:
            # LIBERO
            cmd.linear.x = 0.8
            cmd.angular.z = 0.0
            
            # Wall Following leggero ma reattivo
            if min_left < 0.6:
                cmd.angular.z = -0.4
            elif min_right < 0.6:
                cmd.angular.z = 0.4

        self.publisher_.publish(cmd)

def main(args=None):
    rclpy.init(args=args)
    node = YoubotSimpleAvoidance()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
