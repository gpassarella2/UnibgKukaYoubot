void VelocityController::task() {
    int key = 0;
    key = _kbhit();
    readKeyboard(key);

    // --- LOGICA DI MOVIMENTO AUTOMATICO ---
    // Se non siamo in manual_drive (quindi abbiamo premuto 3), calcoliamo la rotta
    if (!manual_drive) {
        
        // Calcoliamo la distanza e l'angolo ad ogni ciclo del task
        // così se il robot sbanda, si corregge da solo.
        dy = target_y - odo_y; //distanza tra target e robot in y
        dx = target_x - odo_x; //distanza tra target e robot in x
        
        // alpha è l'angolo GLOBALE verso il target
        alpha = atan2(dy, dx);
        
        double distEuclidea = sqrt(dy*dy + dx*dx);
        
        // Se siamo arrivati (tolleranza 0.05 metri) ci fermiamo
        if(distEuclidea <= 0.05 ){
             std::cout << "TARGET RAGGIUNTO" << std::endl;
             twist_vx = 0.0;
             twist_vy = 0.0;
             twist_wz = 0.0;
		    // Torniamo in manuale per sicurezza in maniera che il robot attenda comandi da tastiera
             manual_drive = true; 

        } else {
            // velocità lineare verso target
            twist_vx = 1.0 * cos(alpha + odo_z);
            twist_vy = 1.0 * sin(alpha + odo_z);

            // progressione rotazione questa funzione si puo usare per fermarlo
            double progress = 1.0 - (distEuclidea / dist_iniziale);
            if(progress < 0) progress = 0;
            if(progress > 1) progress = 1;

            // orientamento desiderato progressivo
            double desired_theta = odo_z + progress * (target_z - odo_z);
            double angError = normalizeAngle(desired_theta - odo_z);

            double k_ang = 1.0;
            twist_wz = k_ang * angError;
        }
    }
    // --------------------------------------

    geometry_msgs::msg::dds_::Twist_ twist_msg;
    twist_msg.linear().x(twist_vx);
    twist_msg.linear().y(twist_vy); 
    twist_msg.angular().z(twist_wz);
    twist_pub.publish(&twist_msg);

    odometryCallback(this);
}

