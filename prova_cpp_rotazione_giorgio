void VelocityController::readKeyboard(int key) {
    
    if (key == -1) return;

    if(key==8){
        std::cout << " : X +\n";
        manual_drive = true; // Disattiva auto se tocco i tasti
        twist_vx += 0.1;
    } else if(key==2){
        std::cout << " : X -\n";
        manual_drive = true;
        twist_vx -= 0.1;
    } else if(key==4){
        std::cout << " : Z +\n";
        manual_drive = true;
        twist_wz += 0.1;
    } else if(key==6){
        std::cout << " : Z -\n";
        manual_drive = true;
        twist_wz -= 0.1;
    } else if(key==0){
        std::cout << " : STOP\n";
        manual_drive = true;
        twist_vx = 0.0;
        twist_vy = 0.0;
        twist_wz = 0.0;
    } else if(key==3){
        std::cout << " : GOTO START\n";
        
        // Imposto solo le coordinate, il calcolo vero lo fa il task()
        target_x = 2.69;// coordinata x del traguardo
        target_y = 0.52;// coordinata y del traguardo
        target_z = 1.5707;// orientamento del traguardo 90 gradi a sx

        // memorizzo orientamento e distanza iniziale
        double dx0 = target_x - odo_x;
        double dy0 = target_y - odo_y;
        dist_iniziale = sqrt(dx0*dx0 + dy0*dy0);

        // Abilito la modalità automatica
        manual_drive = false;
        
        std::cout << "Target impostato a: " << target_x << ", " << target_y << std::endl;
        
    }
}
double VelocityController::normalizeAngle(double a) {
    while (a > M_PI) a -= 2*M_PI;
    while (a < -M_PI) a += 2*M_PI;
    return a;
}
