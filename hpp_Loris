#ifndef AURORA_INPUT_READER_ACTIVITY_H
#define AURORA_INPUT_READER_ACTIVITY_H

#include <stresa/core/runtime/VActivity.hpp>

// Include dei messaggi ROS 2 / DDS
#include "stresa/core/msgs/geometry_msgsPubSubTypes.h"
#include "aurora/nav_msgsPubSubTypes.h"

using namespace stresa;

namespace aurora {
namespace components {

class InputReaderActivity : public VActivity {
public:
    InputReaderActivity();
    ~InputReaderActivity();

    // Callbacks statiche per la gestione delle connessioni e ricezione dati
    static void twistConnectionCallback(VariantActivity* va, std::string port, bool matched, int num_connections);
    static void roverOdomConnectionCallback(VariantActivity* va, std::string port, bool matched, int num_connections);
    static void odometryCallback(VariantActivity* va);

protected:
    // Ciclo di vita dell'attività Stresa
    void init();
    void reconfigure();
    void skip();
    void missed();
    void task();
    void quit();

private:
    // --- Comunicazione ---
    VPublisher<geometry_msgs::msg::dds_::Twist_PubSubType> twist_pub;
    VSubscriber<nav_msgs::msg::dds_::Odometry_PubSubType> odometrySub;

    // --- Variabili di Stato del Robot (Aggiornate da Odometria) ---
    double current_x;
    double current_y;
    double current_theta;

    // --- Variabili del Target (Dove vogliamo arrivare) ---
    double target_x;
    double target_y;
    double target_theta;

    // --- Variabili di Controllo (Comandi) ---
    double twist_vx;
    double twist_vy; // Usato poco per diff drive, ma utile se hai omni
    double twist_wz;

    // --- Flag di Logica ---
    bool manual_drive; // true = guida da tastiera, false = guida autonoma
    bool goal_reached; // true = arrivato al target

    // --- Funzioni Helper Private ---
    void readKeyboard(int key);
    
    // Funzioni matematiche per il controllo
    double normalizeAngle(double angle);
    double quaternionToYaw(double x, double y, double z, double w);
    
    // Logica di controllo Rho-Alpha-Beta
    void runAutonomousControl();
};

} // namespace components
} // namespace aurora

#endif
