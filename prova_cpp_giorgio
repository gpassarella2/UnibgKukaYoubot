void VelocityController::task() {
    // 1. Leggi input utente
    int key = _kbhit();
    readKeyboard(key);

    // 2. LOGICA DI CONTROLLO AUTOMATICO
    // Deve stare qui nel loop, non dentro la tastiera, per aggiornarsi continuamente
    if (auto_mode) {
        
        // Calcolo vettore distanza nel mondo GLOBALE
        double dx = target_x - odo_x;
        double dy = target_y - odo_y;
        double distEuclidea = sqrt(dx*dx + dy*dy);

        // Controllo se siamo arrivati (tolleranza 5 cm)
        if(distEuclidea <= 0.05) {
            std::cout << "TARGET RAGGIUNTO!" << std::endl;
            twist_vx = 0.0;
            twist_vy = 0.0;
            twist_wz = 0.0;
            auto_mode = false; // Disattiva automatico
        } 
        else {
            // Calcolo angolo GLOBALE verso il target
            double alpha = atan2(dy, dx);
            
            // Calcolo angolo RELATIVO al robot
            // SOTTRAZIONE: AngoloMondo - AngoloRobot
            double relative_angle = alpha - odo_z; // <--- CORREZIONE MATEMATICA
            
            // Imposto velocità (costante 1.0 m/s o proporzionale)
            double speed = 1.0; 
            
            // Se siamo molto vicini, rallentiamo per non oscillare
            if (distEuclidea < 0.5) speed = 0.3;

            // Proietto la velocità sugli assi LOCALI del robot
            twist_vx = speed * cos(relative_angle);
            twist_vy = speed * sin(relative_angle);
            twist_wz = 0.0; // Manteniamo orientamento fisso (traslazione pura)
            
            // Debug info
            std::cout << "Target Dist: " << distEuclidea << " | OdoZ: " << odo_z << " | RelAng: " << relative_angle << std::endl;
        }
    }

    // 3. Pubblica il messaggio Twist
    geometry_msgs::msg::dds_::Twist_ twist_msg;
    twist_msg.linear().x(twist_vx);
    twist_msg.linear().y(twist_vy); 
    twist_msg.angular().z(twist_wz);
    twist_pub.publish(&twist_msg);

    // Chiama callback per aggiornare dati odometria
    odometryCallback(this);
}

