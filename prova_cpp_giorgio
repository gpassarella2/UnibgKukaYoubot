void VelocityController::readKeyboard(int key) {
    
    if (key == -1) return;

    if(key==8){
        std::cout << " : X +\n";
        manual_drive = true; // Disattiva auto se tocco i tasti
        twist_vx += 0.1;
    } else if(key==2){
        std::cout << " : X -\n";
        manual_drive = true;
        twist_vx -= 0.1;
    } else if(key==4){
        std::cout << " : Z +\n";
        manual_drive = true;
        twist_wz += 0.1;
    } else if(key==6){
        std::cout << " : Z -\n";
        manual_drive = true;
        twist_wz -= 0.1;
    } else if(key==0){
        std::cout << " : STOP\n";
        manual_drive = true;
        twist_vx = 0.0;
        twist_vy = 0.0;
        twist_wz = 0.0;
    } else if(key==3){
        std::cout << " : GOTO START\n";
        
        // Imposto solo le coordinate, il calcolo vero lo fa il task()
        target_x = 2.69;
        target_y = 0.52;
        
        // Abilito la modalità automatica
        manual_drive = false;
        
        std::cout << "Target impostato a: " << target_x << ", " << target_y << std::endl;
    }
}

