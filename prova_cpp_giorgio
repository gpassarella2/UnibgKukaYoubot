void VelocityController::odometryCallback(VariantActivity* va) {
    VelocityController* activity = (VelocityController*) va;

    SampleInfo m_info;
    nav_msgs::msg::dds_::Odometry_ odo_msg;
    
    if(activity->odometrySub.takeNextData(&odo_msg, &m_info)) {
        // Aggiorniamo le variabili membro con la posizione corrente
        activity->odo_x = odo_msg.pose().pose().position().x();
        activity->odo_y = odo_msg.pose().pose().position().y();
        activity->odo_z = odo_msg.pose().pose().orientation().z();
        
        // Debug output (opzionale, puoi commentarlo se sporca troppo la console)
        /*
        std::cout << "ODOM: (" << activity->odo_x << ", " << activity->odo_y << ", " << activity->odo_z << ")" << std::endl;
        */
    }
}

