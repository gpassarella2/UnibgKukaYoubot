void VelocityController::task() {
    int key = 0;
    key = _kbhit();
    readKeyboard(key);

    // --- LOGICA DI MOVIMENTO AUTOMATICO ---
    // Se non siamo in manual_drive (quindi abbiamo premuto 3), calcoliamo la rotta
    if (!manual_drive) {
        
        // Calcoliamo la distanza e l'angolo ad ogni ciclo del task
        // così se il robot sbanda, si corregge da solo.
        dy = target_y - odo_y;
        dx = target_x - odo_x;
        
        // alpha è l'angolo GLOBALE verso il target
        alpha = atan2(dy, dx);
        
        double distEuclidea = sqrt(dy*dy + dx*dx);
        
        // Se siamo arrivati (tolleranza 0.05 metri) ci fermiamo
        if(distEuclidea <= 0.05 ){
             std::cout << "TARGET RAGGIUNTO" << std::endl;
             twist_vx = 0.0;
             twist_vy = 0.0;
             twist_wz = 0.0;
             manual_drive = true; // Torniamo in manuale per sicurezza
        } else {
             // CORREZIONE MATEMATICA:
             // Per trasformare dal mondo al robot, si SOTTRAE l'angolo del robot.
             // Vx = cos(alpha - odo_z)
             // Vy = sin(alpha - odo_z)
             
             twist_vx = 1.0 * cos(alpha + odo_z);
             twist_vy = 1.0 * sin(alpha + odo_z);
             twist_wz = 0.0;
        }
    }
    // --------------------------------------

    geometry_msgs::msg::dds_::Twist_ twist_msg;
    twist_msg.linear().x(twist_vx);
    twist_msg.linear().y(twist_vy); 
    twist_msg.angular().z(twist_wz);
    twist_pub.publish(&twist_msg);

    odometryCallback(this);
}

