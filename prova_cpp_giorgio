void VelocityController::readKeyboard(int key) {
    if (key == -1) return; // Nessun tasto premuto

    if(key==8){
        std::cout << " : X +\n";
        manual_drive = true; auto_mode = false; // Disattiva auto se tocco manuale
        twist_vx += 0.1;
    } else if(key==2){
        std::cout << " : X -\n";
        manual_drive = true; auto_mode = false;
        twist_vx -= 0.1;
    } else if(key==4){
        std::cout << " : Z +\n";
        manual_drive = true; auto_mode = false;
        twist_wz += 0.1;
    } else if(key==6){
        std::cout << " : Z -\n";
        manual_drive = true; auto_mode = false;
        twist_wz -= 0.1;
    } else if(key==0){
        std::cout << " : STOP\n";
        manual_drive = true; 
        auto_mode = false; // <--- Importante: spegne l'automatico
        twist_vx = 0.0;
        twist_vy = 0.0;
        twist_wz = 0.0;
    } else if(key==3){
        std::cout << " : AVVIO GOTO TARGET\n";
        
        // Imposta coordinate target
        target_x = 2.69;
        target_y = 0.52;
        
        // Abilita il flag per il loop in task()
        auto_mode = true; 
        manual_drive = false;
    }
}

