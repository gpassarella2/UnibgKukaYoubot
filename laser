class Laser:
    def __init__(self):
        self.ranges = []
        self.angle_increment = 0.0

    def set_scan(self, ranges, angle_increment):
        self.ranges = ranges
        self.angle_increment = angle_increment

    def get_num_beams(self):
        return len(self.ranges)

    def get_distance(self, index):
        if not self.ranges or index >= len(self.ranges):
            return float('inf')
        return self.ranges[index]


laser = Laser()


