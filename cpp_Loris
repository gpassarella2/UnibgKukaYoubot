// --- Helper Tastiera ---
int _kbhit() {
    static const int STDIN = 0;
    static bool initialized = false;
    if (!initialized) {
        termios term;
        tcgetattr(STDIN, &term);
        term.c_lflag &= ~ICANON;
        tcsetattr(STDIN, TCSANOW, &term);
        setbuf(stdin, NULL);
        initialized = true;
    }
    int bytesWaiting;
    ioctl(STDIN, FIONREAD, &bytesWaiting);
    if(bytesWaiting == 0) return -1;
    return getchar()-48;
}

// --- Costruttore ---
InputReaderActivity::InputReaderActivity() : VActivity() {
    registerPublisher(&twist_pub, "TwistPub", "rt/cmd_vel");
    registerSubscriber(&odometrySub, "OdometrySub", "rt/odom");

    twist_vx = 0.0; twist_vy = 0.0; twist_wz = 0.0;
    current_x = 0.0; current_y = 0.0; current_theta = 0.0;
    manual_drive = true;
    goal_reached = true;
}

InputReaderActivity::~InputReaderActivity() {}

// --- Funzioni Matematiche ---
double InputReaderActivity::normalizeAngle(double angle) {
    while (angle > M_PI) angle -= 2.0 * M_PI;
    while (angle < -M_PI) angle += 2.0 * M_PI;
    return angle;
}

double InputReaderActivity::quaternionToYaw(double x, double y, double z, double w) {
    double siny_cosp = 2.0 * (w * z + x * y);
    double cosy_cosp = 1.0 - 2.0 * (y * y + z * z);
    return std::atan2(siny_cosp, cosy_cosp);
}

// --- Callback Odometria ---
void InputReaderActivity::odometryCallback(VariantActivity* va) {
    InputReaderActivity* activity = (InputReaderActivity*) va;
    SampleInfo m_info;
    nav_msgs::msg::dds_::Odometry_ odo_msg;

    if(activity->odometrySub.takeNextData(&odo_msg, &m_info)) {
        activity->current_x = odo_msg.pose().pose().position().x();
        activity->current_y = odo_msg.pose().pose().position().y();
        
        double qx = odo_msg.pose().pose().orientation().x();
        double qy = odo_msg.pose().pose().orientation().y();
        double qz = odo_msg.pose().pose().orientation().z();
        double qw = odo_msg.pose().pose().orientation().w();
        activity->current_theta = activity->quaternionToYaw(qx, qy, qz, qw);
    }
}

// ============================================================================
// LOGICA DI CONTROLLO (Vettoriale / Omnidirezionale)
// ============================================================================
void InputReaderActivity::runCartesianControl() {
    
    // 1. Errore nel Mondo (Dove voglio andare - Dove sono)
    double global_dx = target_x - current_x;
    double global_dy = target_y - current_y;

    double dist = std::sqrt(global_dx*global_dx + global_dy*global_dy);
    double theta_error = normalizeAngle(target_theta - current_theta);

    // --- STOP ---
    if (dist < 0.05 && std::abs(theta_error) < 0.05) {
        twist_vx = 0.0; twist_vy = 0.0; twist_wz = 0.0;
        goal_reached = true;
        manual_drive = true;
        std::cout << ">>> DESTINAZIONE RAGGIUNTA <<<" << std::endl;
        return;
    }

    // 2. Calcolo Velocità Desiderata nel Mondo
    // Più sono lontano, più vado veloce (fino a un massimo)
    double v_gain = 0.5;
    double w_gain = 1.0;

    double v_world_x = v_gain * global_dx;
    double v_world_y = v_gain * global_dy;

    // Saturazione velocità lineare
    double v_mag = std::sqrt(v_world_x*v_world_x + v_world_y*v_world_y);
    if(v_mag > 0.5) {
        v_world_x = (v_world_x / v_mag) * 0.5;
        v_world_y = (v_world_y / v_mag) * 0.5;
    }

    // 3. ROTAZIONE NEL SISTEMA ROBOT
    // Il robot è girato di 'current_theta'. Dobbiamo ruotare il vettore velocità
    // di -current_theta per sapere quali ruote attivare.
    // Formula rotazione 2D:
    // x' = x cos(a) + y sin(a)
    // y' = -x sin(a) + y cos(a)
    
    double c = std::cos(current_theta);
    double s = std::sin(current_theta);

    twist_vx = v_world_x * c + v_world_y * s;
    twist_vy = -v_world_x * s + v_world_y * c;

    // 4. Rotazione indipendente
    twist_wz = w_gain * theta_error;
    
    // Saturazione angolare
    if(twist_wz > 0.8) twist_wz = 0.8;
    if(twist_wz < -0.8) twist_wz = -0.8;
}

void InputReaderActivity::task() {
    int key = _kbhit();
    if (key != -1) readKeyboard(key);

    if (!manual_drive && !goal_reached) {
        runCartesianControl();
    }

    geometry_msgs::msg::dds_::Twist_ twist_msg;
    twist_msg.linear().x(twist_vx);
    twist_msg.linear().y(twist_vy);
    twist_msg.angular().z(twist_wz);
    twist_pub.publish(&twist_msg);

    odometryCallback(this);
}

// ============================================================================
// INPUT UTENTE (Modificato per inserimento manuale)
// ============================================================================
void InputReaderActivity::readKeyboard(int key) {

    // Comandi Manuali
    if (key == 8) { twist_vx += 0.1; manual_drive = true; }
    else if (key == 2) { twist_vx -= 0.1; manual_drive = true; }
    else if (key == 4) { twist_wz += 0.1; manual_drive = true; }
    else if (key == 6) { twist_wz -= 0.1; manual_drive = true; }
    else if (key == 0) { 
        twist_vx = 0.0; twist_vy = 0.0; twist_wz = 0.0; 
        manual_drive = true; 
        std::cout << "STOP" << std::endl;
    }
    
    // --- TASTO 3: INPUT COORDINATE MANUALE ---
    else if (key == 3) {
        // Ferma tutto prima di chiedere input
        twist_vx = 0; twist_vy = 0; twist_wz = 0;
        manual_drive = false;
        goal_reached = false;

        std::cout << "\n----------------------------------------" << std::endl;
        std::cout << "POSIZIONE ATTUALE: X=" << current_x << " Y=" << current_y << std::endl;
        std::cout << "----------------------------------------" << std::endl;
        
        std::cout << "Inserisci coordinata X Target (Global): ";
        std::cin >> target_x;
        
        std::cout << "Inserisci coordinata Y Target (Global): ";
        std::cin >> target_y;

        // L'angolo finale è fisso: +90 gradi rispetto all'inizio del movimento
        // (Se vuoi inserire anche questo da tastiera, aggiungi cin >> target_theta)
        target_theta = normalizeAngle(current_theta + (M_PI / 2.0));

        std::cout << "--> Vado a (" << target_x << ", " << target_y << ") ruotando a 90 deg." << std::endl;
    }
}

