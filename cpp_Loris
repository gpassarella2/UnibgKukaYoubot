InputReaderActivity::InputReaderActivity() : VActivity() {
    // Registrazione publisher e subscriber
    registerPublisher(&twist_pub, "TwistPub", "rt/cmd_vel");
    registerSubscriber(&odometrySub, "OdometrySub", "rt/odom");

    // Inizializzazione comandi
    twist_vx = 0.0;
    twist_vy = 0.0;
    twist_wz = 0.0;

    // Inizializzazione stato robot
    current_x = 0.0;
    current_y = 0.0;
    current_theta = 0.0;

    // Stato logico
    manual_drive = true;
    goal_reached = true;
}

