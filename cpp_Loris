// ============================================================================
// MATEMATICA E ODOMETRIA
// ============================================================================

// Normalizza l'angolo tra -PI e +PI
double InputReaderActivity::normalizeAngle(double angle) {
    while (angle > M_PI) angle -= 2.0 * M_PI;
    while (angle < -M_PI) angle += 2.0 * M_PI;
    return angle;
}

// Converte Quaternione in Yaw
double InputReaderActivity::quaternionToYaw(double x, double y, double z, double w) {
    double siny_cosp = 2.0 * (w * z + x * y);
    double cosy_cosp = 1.0 - 2.0 * (y * y + z * z);
    return std::atan2(siny_cosp, cosy_cosp);
}

// Callback Odometria: Aggiorna la posizione attuale del robot
void InputReaderActivity::odometryCallback(VariantActivity* va) {
    InputReaderActivity* activity = (InputReaderActivity*) va;
    SampleInfo m_info;
    nav_msgs::msg::dds_::Odometry_ odo_msg;

    if(activity->odometrySub.takeNextData(&odo_msg, &m_info)) {
        // Aggiorna posizione X, Y
        activity->current_x = odo_msg.pose().pose().position().x();
        activity->current_y = odo_msg.pose().pose().position().y();
        
        // Aggiorna Theta (Yaw)
        double qx = odo_msg.pose().pose().orientation().x();
        double qy = odo_msg.pose().pose().orientation().y();
        double qz = odo_msg.pose().pose().orientation().z();
        double qw = odo_msg.pose().pose().orientation().w();
        
        activity->current_theta = activity->quaternionToYaw(qx, qy, qz, qw);
    }
}

// ============================================================================
// LOGICA DI CONTROLLO OMNIDIREZIONALE (Il cuore del movimento)
// ============================================================================
void InputReaderActivity::runAutonomousControl() {
    
    // 1. Vettore Errore Globale
    double dx_global = target_x - current_x;
    double dy_global = target_y - current_y;

    // 2. Distanza dal target (Rho)
    double rho = std::sqrt(dx_global*dx_global + dy_global*dy_global);

    // 3. Errore di Orientamento (Differenza tra angolo desiderato e attuale)
    double theta_error = normalizeAngle(target_theta - current_theta);

    // --- CONDIZIONE DI STOP ---
    // Ci fermiamo se siamo vicini (5cm) E se l'angolo è corretto (entro 0.1 rad ~ 5 gradi)
    if (rho < 0.05 && std::abs(theta_error) < 0.1) {
        twist_vx = 0.0;
        twist_vy = 0.0;
        twist_wz = 0.0;
        goal_reached = true;
        manual_drive = true; // Ritorna al controllo manuale
        std::cout << ">>> TARGET RAGGIUNTO E ALLINEATO! <<<" << std::endl;
        return;
    }

    // --- CALCOLO VELOCITÀ ---

    // A. Velocità Lineare Totale (proporzionale alla distanza)
    double linear_speed = 0.5 * rho; 
    if (linear_speed > 0.5) linear_speed = 0.5; // Saturazione max 0.5 m/s

    // B. Angolo di movimento nel mondo Globale
    // Vogliamo muoverci lungo la linea che congiunge robot e target
    double global_move_angle = std::atan2(dy_global, dx_global);

    // C. Angolo di movimento Locale (Rispetto al robot)
    // Sottraiamo l'orientamento attuale del robot per capire come muovere le ruote
    double local_move_angle = normalizeAngle(global_move_angle - current_theta);

    // D. Scomposizione Velocità Locali (Vx, Vy) per ruote Mecanum
    // Vx = cos(angolo_locale) -> Spinta avanti
    // Vy = sin(angolo_locale) -> Spinta laterale (Slide)
    twist_vx = linear_speed * std::cos(local_move_angle);
    twist_vy = linear_speed * std::sin(local_move_angle);

    // E. Velocità Angolare (Indipendente dalla traslazione)
    // Corregge l'orientamento mentre il robot trasla
    double k_w = 1.0; 
    twist_wz = k_w * theta_error;

    // Saturazione rotazione
    if (twist_wz > 0.8) twist_wz = 0.8;
    if (twist_wz < -0.8) twist_wz = -0.8;

    // Debug opzionale
    // std::cout << "Rho: " << rho << " ThErr: " << theta_error << " Vx: " << twist_vx << " Vy: " << twist_vy << std::endl;
}

// ============================================================================
// TASK PRINCIPALE (Loop)
// ============================================================================
void InputReaderActivity::task() {
    int key = _kbhit();
    
    // Se premo un tasto, gestisco la logica
    if (key != -1) {
        readKeyboard(key); 
    }

    // Se sono in modalità automatica, calcolo le velocità
    if (!manual_drive && !goal_reached) {
        runAutonomousControl();
    }

    // Pubblicazione messaggio Twist (sia manuale che automatico)
    geometry_msgs::msg::dds_::Twist_ twist_msg;
    
    twist_msg.linear().x(twist_vx);
    twist_msg.linear().y(twist_vy); // FONDAMENTALE per movimento omnidirezionale
    twist_msg.angular().z(twist_wz);
    
    twist_pub.publish(&twist_msg);

    // Chiamo callback odometria per avere dati freschi al prossimo ciclo
    odometryCallback(this);
}

// ============================================================================
// INPUT TASTIERA
// ============================================================================
void InputReaderActivity::readKeyboard(int key) {

    // Comandi Manuali
    if(key==8){ // Su
        std::cout << " : X +\n"; 
        twist_vx += 0.1; manual_drive = true; 
    } 
    else if(key==2){ // Giù
        std::cout << " : X -\n"; 
        twist_vx -= 0.1; manual_drive = true; 
    } 
    else if(key==4){ // Sinistra (Rotazione)
        std::cout << " : Z +\n"; 
        twist_wz += 0.1; manual_drive = true; 
    } 
    else if(key==6){ // Destra (Rotazione)
        std::cout << " : Z -\n"; 
        twist_wz -= 0.1; manual_drive = true; 
    } 
    else if(key==0){ // Stop
        std::cout << " : STOP\n"; 
        twist_vx = 0.0; twist_vy = 0.0; twist_wz = 0.0; 
        manual_drive = true; 
    } 
    
    // --- TASTO 3: TRASLAZIONE DRITTA + ROTAZIONE (Omnidirezionale) ---
    else if(key==3){
        std::cout << "\n=== AVVIO TRASLAZIONE LINEARE + ROTAZIONE 90 GRADI ===\n";
        
        // 1. Calcolo il Target: 2 metri DRITTO davanti alla posizione INIZIALE
        double distanza = 2.0; 
        
        // Proietto il punto in avanti basandomi sull'angolo ATTUALE
        target_x = current_x + (distanza * std::cos(current_theta));
        target_y = current_y + (distanza * std::sin(current_theta));
        
        // 2. Calcolo l'orientamento finale desiderato (+90 gradi rispetto a ora)
        target_theta = normalizeAngle(current_theta + (M_PI / 2.0));

        // Attivo il controllo automatico
        manual_drive = false;
        goal_reached = false;

        std::cout << "Posizione Iniziale: (" << current_x << ", " << current_y << ")\n";
        std::cout << "Target Geometrico: (" << target_x << ", " << target_y << ")\n";
        std::cout << "Target Angolo Finale: " << target_theta << " (rad)\n";
    }
    
    else {
        return;
    }
}

