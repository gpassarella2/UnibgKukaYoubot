// --- Helper Tastiera ---
int _kbhit() {
    static const int STDIN = 0;
    static bool initialized = false;
    if (!initialized) {
        termios term;
        tcgetattr(STDIN, &term);
        term.c_lflag &= ~ICANON;
        tcsetattr(STDIN, TCSANOW, &term);
        setbuf(stdin, NULL);
        initialized = true;
    }
    int bytesWaiting;
    ioctl(STDIN, FIONREAD, &bytesWaiting);
    if(bytesWaiting == 0) return -1;
    return getchar()-48;
}

// --- Costruttore ---
InputReaderActivity::InputReaderActivity() : VActivity() {
    registerPublisher(&twist_pub, "TwistPub", "rt/cmd_vel");
    registerSubscriber(&odometrySub, "OdometrySub", "rt/odom");

    twist_vx = 0.0; twist_vy = 0.0; twist_wz = 0.0;
    current_x = 0.0; current_y = 0.0; current_theta = 0.0;
    manual_drive = true;
    goal_reached = true;
}

InputReaderActivity::~InputReaderActivity() {}

// --- Funzioni Matematiche ---
double InputReaderActivity::normalizeAngle(double angle) {
    while (angle > M_PI) angle -= 2.0 * M_PI;
    while (angle < -M_PI) angle += 2.0 * M_PI;
    return angle;
}

double InputReaderActivity::quaternionToYaw(double x, double y, double z, double w) {
    double siny_cosp = 2.0 * (w * z + x * y);
    double cosy_cosp = 1.0 - 2.0 * (y * y + z * z);
    return std::atan2(siny_cosp, cosy_cosp);
}

// --- Callback Odometria ---
void InputReaderActivity::odometryCallback(VariantActivity* va) {
    InputReaderActivity* activity = (InputReaderActivity*) va;
    SampleInfo m_info;
    nav_msgs::msg::dds_::Odometry_ odo_msg;

    if(activity->odometrySub.takeNextData(&odo_msg, &m_info)) {
        activity->current_x = odo_msg.pose().pose().position().x();
        activity->current_y = odo_msg.pose().pose().position().y();
        
        double qx = odo_msg.pose().pose().orientation().x();
        double qy = odo_msg.pose().pose().orientation().y();
        double qz = odo_msg.pose().pose().orientation().z();
        double qw = odo_msg.pose().pose().orientation().w();
        activity->current_theta = activity->quaternionToYaw(qx, qy, qz, qw);
    }
}

// ============================================================================
// LOGICA DI CONTROLLO CARTESIANA
// ============================================================================
void InputReaderActivity::runCartesianControl() {
    
    // 1. Errore Globale (Target Fisso - Posizione Corrente)
    double global_dx = target_x - current_x;
    double global_dy = target_y - current_y;

    // 2. Distanza e Errore Angolare
    double dist = std::sqrt(global_dx*global_dx + global_dy*global_dy);
    double theta_error = normalizeAngle(target_theta - current_theta);

    // Debug Status (ogni tanto)
    static int log_cnt = 0;
    if(log_cnt++ > 100) {
        std::cout << "Dist: " << dist << " | AngErr: " << theta_error << "\r" << std::flush;
        log_cnt = 0;
    }

    // --- STOP: Se siamo vicini (10cm) E l'angolo è giusto (5 gradi) ---
    if (dist < 0.10 && std::abs(theta_error) < 0.1) {
        twist_vx = 0.0; twist_vy = 0.0; twist_wz = 0.0;
        goal_reached = true;
        manual_drive = true;
        std::cout << "\n>>> TARGET RAGGIUNTO <<<" << std::endl;
        return;
    }

    // 3. Calcolo Velocità Desiderata nel MONDO
    double k_v = 0.8; // Reattività lineare
    double k_w = 1.2; // Reattività angolare

    double v_world_x = k_v * global_dx;
    double v_world_y = k_v * global_dy;
    
    // Saturazione (Max 0.5 m/s)
    double v_mag = std::sqrt(v_world_x*v_world_x + v_world_y*v_world_y);
    if(v_mag > 0.5) {
        double scale = 0.5 / v_mag;
        v_world_x *= scale;
        v_world_y *= scale;
    }

    // 4. TRASFORMAZIONE: Mondo -> Robot (per ruote Mecanum)
    // Ruotiamo il vettore velocità mondiale nel sistema locale del robot
    double cos_th = std::cos(current_theta);
    double sin_th = std::sin(current_theta);

    // Vx_robot = proiezione frontale, Vy_robot = proiezione laterale
    twist_vx = v_world_x * cos_th + v_world_y * sin_th;
    twist_vy = -v_world_x * sin_th + v_world_y * cos_th;
    
    // 5. Rotazione su se stesso (indipendente dalla traslazione)
    twist_wz = k_w * theta_error;

    // Saturazione Rotazione
    if(twist_wz > 0.8) twist_wz = 0.8;
    if(twist_wz < -0.8) twist_wz = -0.8;
}

void InputReaderActivity::task() {
    int key = _kbhit();
    if (key != -1) readKeyboard(key);

    if (!manual_drive && !goal_reached) {
        runCartesianControl();
    }

    geometry_msgs::msg::dds_::Twist_ twist_msg;
    twist_msg.linear().x(twist_vx);
    twist_msg.linear().y(twist_vy); // Usa Vy per muoversi in omni
    twist_msg.angular().z(twist_wz);
    twist_pub.publish(&twist_msg);

    odometryCallback(this);
}

// ============================================================================
// INPUT UTENTE: CALCOLO TARGET RELATIVO
// ============================================================================
void InputReaderActivity::readKeyboard(int key) {

    // Manuale
    if (key == 8) { twist_vx += 0.1; manual_drive = true; }
    else if (key == 2) { twist_vx -= 0.1; manual_drive = true; }
    else if (key == 4) { twist_wz += 0.1; manual_drive = true; }
    else if (key == 6) { twist_wz -= 0.1; manual_drive = true; }
    else if (key == 0) { 
        twist_vx = 0; twist_vy = 0; twist_wz = 0; 
        manual_drive = true; 
        std::cout << "STOP" << std::endl;
    }
    
    // --- TASTO 3: INPUT RELATIVO AL ROBOT ---
    else if (key == 3) {
        // Ferma tutto
        twist_vx = 0; twist_vy = 0; twist_wz = 0;
        manual_drive = false;
        goal_reached = false;

        std::cout << "\n----------------------------------------" << std::endl;
        std::cout << "CONFIGURAZIONE PERCORSO (Input Relativo)" << std::endl;
        std::cout << "Posizione Attuale WBT: " << current_x << ", " << current_y << std::endl;
        std::cout << "----------------------------------------" << std::endl;
        
        double rel_x, rel_y;
        std::cout << "Metri in AVANTI (X locale): ";
        std::cin >> rel_x;
        
        std::cout << "Metri di LATO (Y locale, +sx, -dx): ";
        std::cin >> rel_y;

        // --- CALCOLO DEL TARGET GLOBALE ---
        // 1. Prendo lo spostamento locale (es. 2m avanti, 0m lato)
        // 2. Lo ruoto in base a come è girato il robot ORA (current_theta)
        // 3. Lo sommo alla posizione attuale del robot
        
        double cos_th = std::cos(current_theta);
        double sin_th = std::sin(current_theta);

        // Rotazione Vettore + Traslazione
        target_x = current_x + (rel_x * cos_th - rel_y * sin_th);
        target_y = current_y + (rel_x * sin_th + rel_y * cos_th);

        // L'angolo finale è fisso: +90 gradi rispetto a ORA
        target_theta = normalizeAngle(current_theta + (M_PI / 2.0));

        std::cout << "--> Target Globale Calcolato: (" << target_x << ", " << target_y << ")" << std::endl;
        std::cout << "--> Il robot traslera' ruotando..." << std::endl;
    }
}

